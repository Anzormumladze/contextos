{
  "name": "contextos",
  "version": "0.4.0",
  "description": "Meta-MCP proxy \u2014 one server, zero schema bloat, full tool access",
  "type": "module",
  "bin": {
    "contextos": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/server.js",
    "./cli": "./dist/cli.js",
    "./constants": "./dist/constants.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "test:unit": "node dist/test.js",
    "test:integration": "node dist/integration-test.js",
    "test": "npm run build && npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
