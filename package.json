{
  "name": "contextos-risk",
  "version": "1.0.0",
  "description": "Local MCP server — test coverage + edge case + risk intelligence engine for Claude Code",
  "type": "module",
  "bin": {
    "contextos-risk": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/server/index.js",
    "./cli": "./dist/cli.js",
    "./tools": "./dist/tools/index.js",
    "./engines": "./dist/engines/pipeline.js",
    "./types": "./dist/types/index.js"
  },
  "files": [
    "dist/",
    "risk.config.example.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "start": "node dist/cli.js serve",
    "analyze": "node dist/cli.js analyze --pretty"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
